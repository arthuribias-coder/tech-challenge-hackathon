# Chave da API Google Gemini (obrigatório)
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Modo de debug (true/false)
DEBUG=false

# Modelo Gemini a ser utilizado
GEMINI_MODEL=gemini-3.1-pro-preview

# Modelo para chat multiturno com tools (gemini-3.1-flash-lite-preview não tem thinking obrigatório)
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite-preview

# Modelo para validação de diagrama (mais econômico possível, com suporte a visão)
GEMINI_VALIDATOR_MODEL=gemini-3.1-flash-lite-preview

# Tamanho máximo de upload em MB
MAX_UPLOAD_SIZE_MB=10

# Pasta de uploads temporários
UPLOAD_DIR=uploads
