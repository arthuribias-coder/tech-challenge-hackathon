# Chave da API Google Gemini (obrigatório)
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Modo de debug (true/false)
DEBUG=false

# Modelo Gemini a ser utilizado
GEMINI_MODEL=gemini-2.5-flash

# Modelo para chat multiturno com tools
GEMINI_CHAT_MODEL=gemini-2.0-flash

# Modelo para validação de diagrama (mais econômico possível, com suporte a visão)
GEMINI_VALIDATOR_MODEL=gemini-2.0-flash-lite

# Tamanho máximo de upload em MB
MAX_UPLOAD_SIZE_MB=10

# Pasta de uploads temporários
UPLOAD_DIR=uploads

# Roboflow API Key (opcional) — para download de datasets de diagramas do Roboflow Universe
# Obtenha gratuitamente em: https://roboflow.com/ → Settings → Roboflow API
ROBOFLOW_API_KEY=
